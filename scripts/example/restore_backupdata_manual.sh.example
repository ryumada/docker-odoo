#!/usr/bin/env bash
set -e
# Category: Utility
# Description: Restores Odoo data using rsync for filestore and native localhost endpoint for SQL dump.
# Usage: ./scripts/restore_backupdata_manual.sh
# Dependencies: zip, pg_restore, rsync, unzip, curl, sudo, git

# Detect Repository Owner to run non-root commands as that user
CURRENT_DIR=$(dirname "$(readlink -f "$0")")
CURRENT_DIR_USER=$(stat -c '%U' "$CURRENT_DIR")
PATH_TO_ODOO=$(sudo -u "$CURRENT_DIR_USER" git -C "$(dirname "$(readlink -f "$0")")" rev-parse --show-toplevel)
SERVICE_NAME=$(basename "$PATH_TO_ODOO")
REPOSITORY_OWNER=$(stat -c '%U' "$PATH_TO_ODOO")

# Source common utilities
source "$CURRENT_DIR/lib/odoo_utils.sh"

# Configuration
ENV_FILE=".env"
UPDATE_SCRIPT="./scripts/update-env-file.sh"
MAX_BACKUPS=3

# --- Logging Functions & Colors ---
# Define colors for log messages
readonly COLOR_RESET="\033[0m"
readonly COLOR_INFO="\033[0;34m"
readonly COLOR_SUCCESS="\033[0;32m"
readonly COLOR_WARN="\033[1;33m"
readonly COLOR_ERROR="\033[0;31m"

# Function to log messages with a specific color and emoji
log() {
  local color="$1"
  local emoji="$2"
  local message="$3"
  echo -e "${color}[$(date +"%Y-%m-%d %H:%M:%S")] ${emoji} ${message}${COLOR_RESET}"
}

log_info() { log "${COLOR_INFO}" "ℹ️" "$1"; }
log_success() { log "${COLOR_SUCCESS}" "✅" "$1"; }
log_warn() { log "${COLOR_WARN}" "⚠️" "$1"; }
log_error() { log "${COLOR_ERROR}" "❌" "$1"; }


error_handler() {
  local exit_code=$1
  local line_no=$2
  local command_name=$3

  # Restore stderr to the original descriptor to stop logging to the temp file
  if [ -n "${STDERR_LOG:-}" ]; then
    exec 2>&3
  fi

  log_error "An error occurred on line $line_no."
  log_error "Exit Code: $exit_code"
  log_error "Command: $command_name"

  # Allow tee to finish flushing
  sleep 0.2

  if [ -f "${STDERR_LOG:-}" ] && [ -s "$STDERR_LOG" ]; then
    log_error "Captured stderr output:"
    while IFS= read -r line; do
      log_error "  $line"
    done < <(tail -n 20 "$STDERR_LOG")
  fi

  exit "$exit_code"
}

# Save original stderr to file descriptor 3 and redirect to temp file & descriptor 3
STDERR_LOG=$(mktemp)
exec 3>&2
exec 2> >(tee -a "$STDERR_LOG" >&3)

trap 'error_handler $? $LINENO "$BASH_COMMAND"' ERR

# --- Centralized Cleanup Hook ---
cleanup_temp_files() {
    if [ -n "$TEMP_DIR" ] && [ -d "$TEMP_DIR" ]; then
        rm -rf "$TEMP_DIR"
    fi
    if [ -n "$SAFETY_BACKUP_DIR" ] && [ -d "$SAFETY_BACKUP_DIR" ]; then
        rm -rf "$SAFETY_BACKUP_DIR"
    fi
    # Delete temp stderr log
    if [ -n "${STDERR_LOG:-}" ] && [ -f "$STDERR_LOG" ]; then
        rm -f "$STDERR_LOG"
    fi
}
trap cleanup_temp_files EXIT
# ------------------------------------

function get_next_prefix() {
  local env_file="$1"
  local current_count
  local next_count

  # Read existing count
  current_count=$(grep "^DB_PREFIX_COUNT=" "$env_file" | cut -d "=" -f 2 | tr -d '[:space:]')

  # Initialize if empty or not a number
  if [[ ! "$current_count" =~ ^[0-9]+$ ]]; then
    current_count=-1
  fi

  # Increment
  next_count=$((current_count + 1))

  # Reset if > 999
  if [ "$next_count" -gt 999 ]; then
    next_count=0
  fi

  # Update .env file
  if grep -q "^DB_PREFIX_COUNT=" "$env_file"; then
     sed -i "s/^DB_PREFIX_COUNT=.*/DB_PREFIX_COUNT=$next_count/" "$env_file"
  else
     echo "DB_PREFIX_COUNT=$next_count" >> "$env_file"
  fi

  # Output formatted with leading zeros
  printf "%03d" "$next_count"
}

function isBackupDataExists() {
  local backupdata_file_path="$1"
  if [ ! -f "$backupdata_file_path" ]; then
    log_error "Backup data file '$backupdata_file_path' does not exist. Please place your backupdata file in the /tmp directory."
    exit 1
  fi
}

function isPg_restoreInstalled() {
  if ! command -v pg_restore &>/dev/null; then
    log_error "pg_restore is not installed. Please install postgresql-client"
    log_info "Ubuntu: sudo apt install postgresql-client"
    log_info "CentOS: sudo yum install postgresql-client"
    exit 1
  fi
}

function isRsyncInstalled() {
  if ! command -v rsync &>/dev/null; then
    log_error "rsync is not installed. Please install rsync"
    log_info "Ubuntu: sudo apt install rsync"
    log_info "CentOS: sudo yum install rsync"
    exit 1
  fi
}

function isZipAndUnzipInstalled() {
  if ! command -v zip &>/dev/null; then
    log_error "zip is not installed. Please install zip"
    log_info "Ubuntu: sudo apt install zip"
    log_info "CentOS: sudo yum install zip"
    exit 1
  fi
  if ! command -v unzip &>/dev/null; then
    log_error "unzip is not installed. Please install unzip"
    log_info "Ubuntu: sudo apt install unzip"
    log_info "CentOS: sudo yum install unzip"
    exit 1
  fi
}

function run_psql() {
  local env_file="${PSQL_ENV_FILE:-$PATH_TO_ODOO/.env}"
  local db_host=$(grep "^DB_HOST=" "$env_file" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
  if [ -n "$db_host" ] && [ "$db_host" != "localhost" ]; then
    local db_port=$(grep "^DB_PORT=" "$env_file" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
    local db_user=$(cat "$(dirname "$env_file")/.secrets/db_user" 2>/dev/null || true)
    local db_pass=$(cat "$(dirname "$env_file")/.secrets/db_password" 2>/dev/null || true)
    local docker_net=$(grep "^DOCKER_NETWORK_MODE=" "$env_file" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
    [ -z "$db_port" ] && db_port="5432"
    [ -z "$docker_net" ] && docker_net="host"
    local net=$(echo "$docker_net" | cut -d "," -f 1)
    docker run -i --rm --network="$net" -e PGPASSWORD="$db_pass" postgres psql -h "$db_host" -p "$db_port" -U "$db_user" "$@"
  else
    sudo -u postgres psql "$@"
  fi
}

function run_pg_dump() {
  local env_file="${PSQL_ENV_FILE:-$PATH_TO_ODOO/.env}"
  local db_host=$(grep "^DB_HOST=" "$env_file" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
  if [ -n "$db_host" ] && [ "$db_host" != "localhost" ]; then
    local db_port=$(grep "^DB_PORT=" "$env_file" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
    local db_user=$(cat "$(dirname "$env_file")/.secrets/db_user" 2>/dev/null || true)
    local db_pass=$(cat "$(dirname "$env_file")/.secrets/db_password" 2>/dev/null || true)
    local docker_net=$(grep "^DOCKER_NETWORK_MODE=" "$env_file" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
    [ -z "$db_port" ] && db_port="5432"
    [ -z "$docker_net" ] && docker_net="host"
    local net=$(echo "$docker_net" | cut -d "," -f 1)
    docker run -i --rm --network="$net" -e PGPASSWORD="$db_pass" postgres pg_dump -h "$db_host" -p "$db_port" -U "$db_user" "$@"
  else
    sudo -u postgres pg_dump "$@"
  fi
}

function sanitizeDatabase() {
  local restored_db_name="$1"
  log_info "Neutralizing the database (SMTP, Crons, Webhooks, Payments, and activating Neutralized Banner)..."

  # SQL commands to disable outgoing email, crons, mail servers, and activate the banner.
  # Wrapped in a PL/pgSQL DO block to avoid failures if optional modules are not installed.
  local SANITIZE_SQL
  SANITIZE_SQL=$(cat << 'EOF'
    DO $$
    BEGIN
        -- 1. Base Module Neutralization
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'ir_mail_server' AND column_name = 'active') THEN
            EXECUTE 'UPDATE ir_mail_server SET active = false';
            EXECUTE 'INSERT INTO ir_mail_server(name, smtp_port, smtp_host, smtp_encryption, active, smtp_authentication)
            VALUES (''neutralization - disable emails'', 1025, ''invalid'', ''none'', true, ''login'')
            ON CONFLICT DO NOTHING';
        END IF;

        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'ir_cron' AND column_name = 'active') THEN
            EXECUTE 'UPDATE ir_cron
               SET active = false
             WHERE id NOT IN (
                   SELECT res_id
                     FROM ir_model_data
                    WHERE model = ''ir.cron''
                      AND name = ''autovacuum_job''
                      AND module = ''base''
             )';
        END IF;

        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'ir_config_parameter' AND column_name = 'key') THEN
            EXECUTE 'INSERT INTO ir_config_parameter (key, value)
            VALUES (''database.is_neutralized'', true)
                ON CONFLICT (key) DO UPDATE SET value = true';
        END IF;

        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'ir_act_server' AND column_name = 'webhook_url') THEN
            EXECUTE 'UPDATE ir_act_server SET webhook_url = ''neutralization - disable webhook'' WHERE state = ''webhook''';
        END IF;

        -- 2. Mail Module Neutralization
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'mail_template' AND column_name = 'mail_server_id') THEN
            EXECUTE 'UPDATE mail_template SET mail_server_id = NULL';
        END IF;

        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'fetchmail_server' AND column_name = 'active') THEN
            EXECUTE 'UPDATE fetchmail_server SET active = false';
        END IF;

        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'ir_config_parameter' AND column_name = 'key') THEN
            EXECUTE 'DELETE FROM ir_config_parameter WHERE key IN (''mail.web_push_vapid_private_key'', ''mail.web_push_vapid_public_key'', ''mail.sfu_server_key'')';
        END IF;

        IF EXISTS (SELECT FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'mail_push') THEN
            EXECUTE 'TRUNCATE mail_push CASCADE';
        END IF;

        IF EXISTS (SELECT FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'mail_push_device') THEN
            EXECUTE 'DELETE FROM mail_push_device';
        END IF;

        -- 3. Web Module Neutralization (Activate Neutralize Banner)
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'ir_ui_view' AND column_name = 'active') THEN
            EXECUTE 'UPDATE ir_ui_view SET active = true WHERE key = ''web.neutralize_banner''';
        END IF;

        -- 4. Additional Common Services
        -- Disable Payment Providers
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'payment_provider' AND column_name = 'state') THEN
            EXECUTE 'UPDATE payment_provider SET state = ''disabled'' WHERE state NOT IN (''test'', ''disabled'')';
        END IF;

        -- Disable OAuth login
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'auth_oauth_provider' AND column_name = 'enabled') THEN
            EXECUTE 'UPDATE auth_oauth_provider SET enabled = false';
        END IF;

        -- Disable Google Calendar sync
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'res_users_settings' AND column_name = 'google_calendar_rtoken') THEN
            EXECUTE 'UPDATE res_users_settings SET google_calendar_rtoken = NULL, google_calendar_token = NULL, google_synchronization_stopped = True';
        END IF;

        -- Disable IAP accounts
        IF EXISTS (SELECT FROM information_schema.columns WHERE table_schema = 'public' AND table_name = 'iap_account' AND column_name = 'account_token') THEN
            EXECUTE 'UPDATE iap_account SET account_token = REGEXP_REPLACE(account_token, ''(\+.*)?$'', ''+disabled'') WHERE LENGTH(account_token) <= 33';
            EXECUTE 'UPDATE iap_account SET account_token = ''dummy_value+disabled'' WHERE LENGTH(account_token) > 33 AND account_token NOT LIKE ''%+disabled''';
        END IF;
    END $$;
EOF
)

  # Execute the SQL commands
  if run_psql -d "$restored_db_name" -c "$SANITIZE_SQL" > /dev/null 2>&1; then
    log_success "Database successfully neutralized."
  else
    log_warn "Warning: Failed to sanitize database completely (SQL command failed)."
  fi
}

function main() {
  # Self-elevate to root if not already
  if [ "$(id -u)" -ne 0 ]; then
      log_info "Elevating permissions to root..."
      # shellcheck disable=SC2093
      exec sudo "$0" "$@" # Re-run the script with sudo
      exit 1
  fi

  # Ensure secret file exists
  if [ ! -f "$PATH_TO_ODOO/.secrets/db_user" ]; then
    log_error "Secret file .secrets/db_user not found in $PATH_TO_ODOO"
    exit 1
  fi
  ODOO_DB_USER=$(cat "$PATH_TO_ODOO/.secrets/db_user")

  BACKUP_RESTORE_METHOD=$(grep "^BACKUP_RESTORE_METHOD=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)

  ADMIN_PASSWD=$(grep "^ADMIN_PASSWD=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
  PORT=$(grep "^PORT=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
  if [ "$BACKUP_RESTORE_METHOD" != "manual" ]; then
    if [ -z "$ADMIN_PASSWD" ] || [ -z "$PORT" ]; then
      log_error "ADMIN_PASSWD and/or PORT not set in .env file. Cannot proceed with endpoint restore."
      exit 1
    fi
  fi

  BACKUPDATA_FILE_NAME="backupdata-$SERVICE_NAME.zip"
  BACKUPDATA_FILE_PATH="/tmp/$BACKUPDATA_FILE_NAME"
  TEMP_DIR="/tmp/backupdata-$SERVICE_NAME"
  RESTORED_DB_NAME=""

  isBackupDataExists "$BACKUPDATA_FILE_PATH"
  isRsyncInstalled
  isPg_restoreInstalled
  isZipAndUnzipInstalled

  log_info "Start restoring backup data for $SERVICE_NAME"

  while true; do
    # Using || true to prevent grep failure from triggering set -e if key is missing
    PROMPT_FOR_DATABASE_NAME=$(grep "^PROMPT_FOR_DATABASE_NAME=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)

    if [ -z "$PROMPT_FOR_DATABASE_NAME" ]; then
      ODOO_DATABASE_NAME_PRD=$(grep "^DB_NAME=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
      if [ -z "$ODOO_DATABASE_NAME_PRD" ]; then
        RESTORED_DB_NAME="$(get_next_prefix "$PATH_TO_ODOO/.env")-$SERVICE_NAME-$(date +"%Y%m%d-%H%M%S")"
      else
        RESTORED_DB_NAME="$ODOO_DATABASE_NAME_PRD"
      fi
    else
      # Prompting logic
      echo -n -e "${COLOR_INFO}[$(date +"%Y-%m-%d %H:%M:%S")] ℹ️  Enter the new database name: ${COLOR_RESET}"
      read -r RESTORED_DB_NAME
    fi

    log_info "Database name would be: $RESTORED_DB_NAME"

    log_info "Checking if the database exists..."
    if run_psql -c '\l' | grep -wq "$RESTORED_DB_NAME"; then
      log_warn "Database $RESTORED_DB_NAME already exists. Initiating safety backup..."

      SAFETY_BACKUP_NAME="backupdata-$SERVICE_NAME-safety-backup-$(date +"%Y%m%d-%H%M%S").zip"
      SAFETY_BACKUP_DIR="/tmp/safety_backup_tmp_$(date +"%Y%m%d-%H%M%S")"
      SAFETY_ZIP_PATH="/tmp/$SAFETY_BACKUP_NAME"
      EXISTING_FILESTORE="/var/lib/odoo/$SERVICE_NAME/filestore/$RESTORED_DB_NAME"

      mkdir -p "$SAFETY_BACKUP_DIR"

      log_info "Dumping database $RESTORED_DB_NAME to $SAFETY_BACKUP_DIR/dump.sql"
      if ! run_pg_dump "$RESTORED_DB_NAME" > "$SAFETY_BACKUP_DIR/dump.sql"; then
          log_error "Failed to dump database $RESTORED_DB_NAME. Aborting restore."
          exit 1
      fi

      log_info "Copying filestore from $EXISTING_FILESTORE"
      if [ -d "$EXISTING_FILESTORE" ]; then
          mkdir -p "$SAFETY_BACKUP_DIR/filestore"
          cp -r "$EXISTING_FILESTORE/." "$SAFETY_BACKUP_DIR/filestore/"
      else
          log_warn "Filestore not found at $EXISTING_FILESTORE. Proceeding with SQL dump only."
      fi

      log_info "Zipping safety backup to $SAFETY_ZIP_PATH"
      if ! (cd "$SAFETY_BACKUP_DIR" && zip -r -q "$SAFETY_ZIP_PATH" .); then
          log_error "Failed to zip safety backup. Aborting restore."
          exit 1
      fi

      chown "$SUDO_USER:$SUDO_USER" "$SAFETY_ZIP_PATH"
      log_success "Safety backup created at $SAFETY_ZIP_PATH"

      log_info "Dropping existing database $RESTORED_DB_NAME..."
      if ! run_psql -c "DROP DATABASE \"$RESTORED_DB_NAME\" WITH (FORCE)"; then
          log_error "Failed to drop database $RESTORED_DB_NAME. Aborting."
          exit 1
      fi

      log_info "Removing existing filestore..."
      if [ -d "$EXISTING_FILESTORE" ]; then
          rm -rf "$EXISTING_FILESTORE"
      fi

      log_success "Existing database and filestore removed. Proceeding with restore."
      break
    else
      log_success "Database name '$RESTORED_DB_NAME' is available."
      break
    fi
  done

  FILESTORE_PATH="/var/lib/odoo/$SERVICE_NAME/filestore/$RESTORED_DB_NAME"

  log_info "Creating a temporary directory: $TEMP_DIR"
  mkdir -p "$TEMP_DIR"

  log_info "Extracting the zip backup file (this may take a while)..."
  unzip -qqqq -d "$TEMP_DIR" "$BACKUPDATA_FILE_PATH" >&2
  chmod -R a+rX "$TEMP_DIR"

  log_info "Creating the filestore directory at $FILESTORE_PATH"
  mkdir -p "$FILESTORE_PATH"

  log_info "Restoring the filestore files..."
  if [ -d "$TEMP_DIR/filestore" ]; then
    rsync -a "$TEMP_DIR/filestore/" "$FILESTORE_PATH"
  else
    log_warn "Filestore not found in backup. Skipping filestore restore."
  fi

  log_info "Changing the ownership of $FILESTORE_PATH to odoo user"
  chown -R odoo: "$FILESTORE_PATH"

  NEUTRALIZE_DB=$(grep "^NEUTRALIZE_DATABASE=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]]*//g' | sed 's/[[:space:]]*$//g' || true)
  if [ -z "$NEUTRALIZE_DB" ]; then
    NEUTRALIZE_DB="true"
  fi

  log_info "Neutralize database option: $NEUTRALIZE_DB"

  if [ "$BACKUP_RESTORE_METHOD" = "manual" ]; then
      # --- PURE MANUAL PSQL RESTORE ---
      ODOO_VERSION=$(grep "^ODOO_VERSION=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
      ODOO_VERSION_NUM=${ODOO_VERSION%%.*}
      if [[ ! "$ODOO_VERSION_NUM" =~ ^[0-9]+$ ]]; then
        if [[ "$ODOO_VERSION" == "latest" ]]; then
          ODOO_VERSION_NUM=18
        else
          ODOO_VERSION_NUM=16
        fi
      fi
      log_info "Detected target Odoo Version: ${ODOO_VERSION:-16} (Numeric: $ODOO_VERSION_NUM)"

      DB_USER=$(cat "$(dirname "$PATH_TO_ODOO/.env")/.secrets/db_user" 2>/dev/null || echo "odoo")

      log_info "Dropping old database $RESTORED_DB_NAME (with force)"
      run_psql -d postgres -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$RESTORED_DB_NAME' AND pid <> pg_backend_pid();" > /dev/null 2>&1 || true
      run_psql -d postgres -c "DROP DATABASE IF EXISTS \"$RESTORED_DB_NAME\"" >/dev/null

      log_info "Creating new database $RESTORED_DB_NAME with owner $DB_USER"
      run_psql -d postgres -c "CREATE DATABASE \"$RESTORED_DB_NAME\" OWNER \"$DB_USER\"" >/dev/null

      log_info "Restoring database from SQL dump via psql..."
      run_psql -d "$RESTORED_DB_NAME" < "$TEMP_DIR/dump.sql" >/dev/null

      log_success "Database restored successfully via psql."

      log_info "Altering database object ownership..."
      local POSTGRES_USER_DEV="$DB_USER"
      run_psql -d "$RESTORED_DB_NAME" -c "
        -- Change the owner of all tables
        DO \$\$
        DECLARE
            rec RECORD;
        BEGIN
            FOR rec IN (SELECT tablename FROM pg_tables WHERE schemaname = 'public') LOOP
                EXECUTE 'ALTER TABLE ' || quote_ident(rec.tablename) || ' OWNER TO \"${POSTGRES_USER_DEV}\"';
            END LOOP;
        END \$\$;

        -- Change the owner of all sequences
        DO \$\$
        DECLARE
            rec RECORD;
        BEGIN
            FOR rec IN (SELECT sequence_name FROM information_schema.sequences WHERE sequence_schema = 'public') LOOP
                EXECUTE 'ALTER SEQUENCE ' || quote_ident(rec.sequence_name) || ' OWNER TO \"${POSTGRES_USER_DEV}\"';
            END LOOP;
        END \$\$;

        -- Change the owner of all views (Standard)
        DO \$\$
        DECLARE
            rec RECORD;
        BEGIN
            FOR rec IN (SELECT table_name FROM information_schema.views WHERE table_schema = 'public') LOOP
                EXECUTE 'ALTER VIEW ' || quote_ident(rec.table_name) || ' OWNER TO \"${POSTGRES_USER_DEV}\"';
            END LOOP;
        END \$\$;

        -- Change the owner of all materialized views
        DO \$\$
        DECLARE
            rec RECORD;
        BEGIN
            FOR rec IN (SELECT matviewname FROM pg_matviews WHERE schemaname = 'public') LOOP
                EXECUTE 'ALTER MATERIALIZED VIEW ' || quote_ident(rec.matviewname) || ' OWNER TO \"${POSTGRES_USER_DEV}\"';
            END LOOP;
        END \$\$;
      "

      if [ "$NEUTRALIZE_DB" = "true" ]; then
         sanitizeDatabase "$RESTORED_DB_NAME"
      fi
  else
      # --- SEMI_MANUAL ENDPOINT RESTORE ---
      log_info "Compressing dump.sql into db_dump_only.zip for Odoo endpoint import..."
      if [ -f "$TEMP_DIR/dump.sql" ]; then
        (cd "$TEMP_DIR" && zip -q db_dump_only.zip dump.sql)
      else
        log_error "dump.sql not found in extracted backup. Aborting."
        exit 1
      fi

      ODOO_VERSION=$(grep "^ODOO_VERSION=" "$PATH_TO_ODOO/.env" | cut -d "=" -f 2 | sed 's/^[[:space:]\n]*//g' | sed 's/[[:space:]\n]*$//g' || true)
      ODOO_VERSION_NUM=${ODOO_VERSION%%.*}
      if [[ ! "$ODOO_VERSION_NUM" =~ ^[0-9]+$ ]]; then
        if [[ "$ODOO_VERSION" == "latest" ]]; then
          ODOO_VERSION_NUM=18
        else
          ODOO_VERSION_NUM=16
        fi
      fi
      log_info "Detected target Odoo Version: ${ODOO_VERSION:-16} (Numeric: $ODOO_VERSION_NUM)"

      log_info "Restoring database schema/data via direct localhost endpoint..."
      if [ "$ODOO_VERSION_NUM" -ge 16 ]; then
        response=$(curl -s -X POST \
          -F "master_pwd=$ADMIN_PASSWD" \
          -F "name=$RESTORED_DB_NAME" \
          -F "backup_file=@$TEMP_DIR/db_dump_only.zip" \
          -F "copy=true" \
          -F "neutralize_database=$NEUTRALIZE_DB" \
          "http://localhost:$PORT/web/database/restore")
      else
        response=$(curl -s -X POST \
          -F "master_pwd=$ADMIN_PASSWD" \
          -F "name=$RESTORED_DB_NAME" \
          -F "backup_file=@$TEMP_DIR/db_dump_only.zip" \
          -F "copy=true" \
          "http://localhost:$PORT/web/database/restore")
      fi

      response_lower="${response,,}"
      if [[ "$response_lower" == *"redirecting"* ]] && [[ "$response_lower" == *"/web/database/manager"* ]]; then
        log_success "Database restore command completed successfully."
      elif [[ "$response_lower" == *"error"* ]] || \
           [[ "$response_lower" == *"incorrect master password"* ]] || \
           [ -z "$response" ]; then
        log_error "Failed to restore database via endpoint. Response: ${response:-'Empty response'}"
        exit 1
      else
        log_success "Database restore command completed."
      fi

      if [ "$NEUTRALIZE_DB" = "true" ] && [ "$ODOO_VERSION_NUM" -lt 16 ]; then
        log_info "Odoo version < 16 detected. Performing manual SQL database neutralization fallback..."
        sanitizeDatabase "$RESTORED_DB_NAME"
      fi
  fi

  trigger_registry_reload "$RESTORED_DB_NAME" "$PATH_TO_ODOO"

  log_success "Finished restoring backup data for $SERVICE_NAME"
}

main "$@"
